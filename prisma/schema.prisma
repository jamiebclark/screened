generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MediaType {
  MOVIE
  TV
}

enum WatchStatus {
  WATCHLIST
  WATCHING
  WATCHED
  DROPPED
}

enum ListRole {
  OWNER
  CONTRIBUTOR
  VIEWER
}

enum PreferenceType {
  ATTRACTOR
  REPELLER
}

enum WatchEntrySource {
  PLEX
  TAUTULLI
  LETTERBOXD
  JELLYFIN
  TRAKT
  MANUAL
  UNKNOWN
}

enum ListAccessRequestStatus {
  PENDING
  APPROVED
  DENIED
}

enum NotificationType {
  LIST_ACCESS_REQUEST
  FRIEND_REQUEST
  FRIEND_WATCHED_YOUR_WATCHLIST
}

/// Who can see a profile section. All values apply to signed-in users only; this app is login-protected.
enum ProfileContentVisibility {
  /// Any Screened user.
  PUBLIC
  /// Only users you have friended.
  FRIENDS
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  avatarUrl     String?
  bio           String?
  /// Secret query token for the per-user Radarr watchlist export (movies only). Unique when set.
  watchlistRadarrToken String? @unique
  /// Watchlist tab and item grid on your profile.
  watchlistVisibility ProfileContentVisibility @default(PUBLIC)
  /// Watched and watching activity on your profile (and related stat counts / average rating from visible titles).
  watchHistoryVisibility ProfileContentVisibility @default(PUBLIC)
  /// Set when the user finishes or skips first-login onboarding (connect Letterboxd / Plex). Null = show onboarding.
  onboardingCompletedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  plexConnection        PlexConnection?
  letterboxdConnection  LetterboxdConnection?
  tautulliConnection    TautulliConnection?
  jellyfinConnection    JellyfinConnection?
  traktConnection       TraktConnection?
  overseerrConnection   OverseerrConnection?
  discordConnection     DiscordConnection?
  mediaStatuses         UserMediaStatus[]
  watchEntries          WatchEntry[]
  episodeStatuses       EpisodeStatus[]
  ownedLists      List[]
  listMemberships ListMember[]
  listItems       ListItem[]
  sessions        Session[]
  preferences     UserPreference[]
  pickerRooms     PickerRoom[]        @relation("PickerRoomOwner")
  pickerSessions  PickerSession[]     @relation("PickerSessionOwner")
  pickerPresets   PickerRoomPreset[]  @relation("PickerRoomPresetOwner")
  accessRequestsMade     ListAccessRequest[] @relation("AccessRequestRequester")
  accessRequestsResolved ListAccessRequest[] @relation("AccessRequestResolver")
  notifications          Notification[]

  friendRequestsSent     FriendRequest[]  @relation("FriendRequestFrom")
  friendRequestsReceived FriendRequest[]  @relation("FriendRequestTo")
  friendshipsLower       Friendship[]     @relation("FriendUserLow")
  friendshipsUpper       Friendship[]     @relation("FriendUserHigh")
  signupInvitesCreated   SignupInvite[]  @relation("SignupInviteCreatedBy")
}

/// Single- or multi-use token for self-service signup when public registration is disabled.
model SignupInvite {
  id          String    @id @default(cuid())
  tokenHash   String    @unique
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?
  revokedAt   DateTime?
  maxUses     Int       @default(1)
  uses        Int       @default(0)
  note        String?
  createdById String?
  createdBy   User?     @relation("SignupInviteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PlexConnection {
  id           String    @id @default(cuid())
  userId       String    @unique
  plexToken    String
  plexClientId String
  plexUsername String?
  plexServerId String?
  lastSyncedAt DateTime?
  /// Serialized Map<tmdbId, ratingKey> as [number, string][] for fast page loads.
  libraryCache    Json?
  libraryCachedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LetterboxdConnection {
  id                 String    @id @default(cuid())
  userId             String    @unique
  letterboxdUsername String
  lastSyncedAt       DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TautulliConnection {
  id               String    @id @default(cuid())
  userId           String    @unique
  tautulliUrl      String
  apiKey           String
  /// Plex username to filter history by (recommended on shared servers).
  tautulliUsername String?
  lastSyncedAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JellyfinConnection {
  id               String    @id @default(cuid())
  userId           String    @unique
  serverUrl        String
  apiKey           String
  jellyfinUserId   String
  jellyfinUsername String
  lastSyncedAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TraktConnection {
  id           String    @id @default(cuid())
  userId       String    @unique
  traktUsername String
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OverseerrConnection {
  id        String   @id @default(cuid())
  userId    String   @unique
  serverUrl String
  apiKey    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DiscordConnection {
  id              String    @id @default(cuid())
  userId          String    @unique
  discordUserId   String    @unique
  discordUsername String
  accessToken     String
  refreshToken    String?
  expiresAt       DateTime?
  dmEnabled       Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MediaItem {
  id        String    @id @default(cuid())
  tmdbId    Int
  type      MediaType
  title     String
  poster    String?
  backdrop  String?
  year      Int?
  overview  String?
  genres    String[]
  runtime   Int?
  cast      String[]  @default([])
  director  String?
  keywords  String[]  @default([])
  embedding Float[]  @default([])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  userStatuses    UserMediaStatus[]
  watchEntries    WatchEntry[]
  episodeStatuses EpisodeStatus[]
  listItems       ListItem[]
  preferences     UserPreference[]

  @@unique([tmdbId, type])
}

/// Cached OMDb "Ratings" (RT, Metacritic, IMDb, etc.) keyed by IMDb title id. Optional feature when OMDB_API_KEY is set.
model OmdbRatingCache {
  imdbId              String   @id
  ratings             Json
  /// From OMDb with tomatoes=true; used for the RT score link.
  rottenTomatoesUrl   String?
  fetchedAt           DateTime
}

model UserMediaStatus {
  id          String      @id @default(cuid())
  userId      String
  mediaItemId String
  status      WatchStatus
  rating      Float?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaItem    MediaItem    @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  watchEntries WatchEntry[]

  @@unique([userId, mediaItemId])
}

model WatchEntry {
  id                String             @id @default(cuid())
  userId            String
  mediaItemId       String
  userMediaStatusId String?
  source            WatchEntrySource   @default(UNKNOWN)
  watchedAt         DateTime           @default(now())
  review            String?
  rating            Float?
  /// Letterboxd diary URL from RSS (item link) when synced from Letterboxd.
  letterboxdActivityUrl String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaItem       MediaItem        @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  userMediaStatus UserMediaStatus? @relation(fields: [userMediaStatusId], references: [id], onDelete: SetNull)
  notifications   Notification[]
}

model EpisodeStatus {
  id            String    @id @default(cuid())
  userId        String
  mediaItemId   String
  seasonNumber  Int
  episodeNumber Int
  watchedAt     DateTime  @default(now())
  /// False = unchecked in the UI; watchedAt is kept so re-checking restores the prior watch time.
  isWatched     Boolean   @default(true)
  /// Optional markdown review for this episode (TV title page “Log” on the episode row).
  review        String?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaItem MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaItemId, seasonNumber, episodeNumber])
}

model List {
  id                 String   @id @default(cuid())
  name               String
  description        String?
  slug               String   @unique
  isPublic           Boolean  @default(true)
  ownerId            String
  radarrToken        String?  @unique
  discordWebhookUrl  String?
  discordWebhookId   String?
  discordChannelName String?
  discordGuildName   String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  owner          User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members        ListMember[]
  items          ListItem[]
  accessRequests ListAccessRequest[]
}

model ListMember {
  id        String   @id @default(cuid())
  listId    String
  userId    String
  role      ListRole @default(CONTRIBUTOR)
  createdAt DateTime @default(now())

  list List @relation(fields: [listId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([listId, userId])
}

model ListItem {
  id          String    @id @default(cuid())
  listId      String
  mediaItemId String
  addedById   String
  notes       String?
  addedAt     DateTime  @default(now())

  list      List      @relation(fields: [listId], references: [id], onDelete: Cascade)
  mediaItem MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  addedBy   User      @relation(fields: [addedById], references: [id], onDelete: Cascade)

  @@unique([listId, mediaItemId])
}

model UserPreference {
  id          String         @id @default(cuid())
  userId      String
  type        PreferenceType
  mediaItemId String
  weight      Float          @default(1.0)
  createdAt   DateTime       @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaItem MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaItemId, type])
}

model PickerRoom {
  id          String   @id @default(cuid())
  createdById String
  state       Json
  version     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User           @relation("PickerRoomOwner", fields: [createdById], references: [id], onDelete: Cascade)
  sessions  PickerSession[]
}

/// Saved snapshot of a completed picker room session.
model PickerSession {
  id           String   @id @default(cuid())
  createdById  String
  roomId       String?
  /// Participant snapshots: { id, name, avatarUrl }[]
  participants Json
  /// Attractor seeds used for scoring: ReferenceMovieJson[]
  attractors   Json
  /// Top scored results at time of save: ScoredMovieJson[]
  results      Json
  /// TMDB id of the title recorded as "picked", if any
  pickedTmdbId Int?
  createdAt    DateTime @default(now())

  createdBy User        @relation("PickerSessionOwner", fields: [createdById], references: [id], onDelete: Cascade)
  room      PickerRoom? @relation(fields: [roomId], references: [id], onDelete: SetNull)
}

/// Named preset: saved participants + attractor seeds for quick room creation.
model PickerRoomPreset {
  id           String   @id @default(cuid())
  createdById  String
  name         String
  /// User IDs of participants to pre-populate: string[]
  participantIds Json
  /// Seed attractors: ReferenceMovieJson[]
  attractors   Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdBy User @relation("PickerRoomPresetOwner", fields: [createdById], references: [id], onDelete: Cascade)
}

model ListAccessRequest {
  id           String                  @id @default(cuid())
  listId       String
  requesterId  String
  status       ListAccessRequestStatus @default(PENDING)
  message      String?
  resolvedAt   DateTime?
  resolvedById String?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  list          List           @relation(fields: [listId], references: [id], onDelete: Cascade)
  requester     User           @relation("AccessRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  resolver      User?          @relation("AccessRequestResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  notifications Notification[]

  @@unique([listId, requesterId])
  @@index([listId, status])
}

model Notification {
  id                  String           @id @default(cuid())
  userId              String
  type                NotificationType
  readAt              DateTime?
  listAccessRequestId String?
  friendRequestId     String?
  watchEntryId        String?
  createdAt           DateTime         @default(now())

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  listAccessRequest ListAccessRequest? @relation(fields: [listAccessRequestId], references: [id], onDelete: Cascade)
  friendRequest     FriendRequest?     @relation(fields: [friendRequestId], references: [id], onDelete: Cascade)
  watchEntry        WatchEntry?        @relation(fields: [watchEntryId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([listAccessRequestId])
  @@index([friendRequestId])
  @@index([watchEntryId])
}

/// Pending friend request from one user to another (one row per direction).
model FriendRequest {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  fromUser      User            @relation("FriendRequestFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser        User            @relation("FriendRequestTo", fields: [toUserId], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@unique([fromUserId, toUserId])
  @@index([toUserId])
  @@index([fromUserId])
}

/// Accepted friendship; `userLowId` is always the lexicographically smaller user id.
model Friendship {
  id         String   @id @default(cuid())
  userLowId  String
  userHighId String
  createdAt  DateTime @default(now())

  userLow  User @relation("FriendUserLow", fields: [userLowId], references: [id], onDelete: Cascade)
  userHigh User @relation("FriendUserHigh", fields: [userHighId], references: [id], onDelete: Cascade)

  @@unique([userLowId, userHighId])
  @@index([userHighId])
  @@index([userLowId])
}
