# Database
DATABASE_URL="postgresql://movienight:movienight@db:5432/movienightdb?schema=public"

# Auth.js
AUTH_SECRET="change-me-to-a-random-32-char-string"
NEXTAUTH_URL="http://localhost:3000"

# TMDB API (https://www.themoviedb.org/settings/api)
TMDB_API_KEY="your-tmdb-api-read-access-token"

# Optional: OMDb (https://www.omdbapi.com) — extra scores (e.g. Rotten Tomatoes) on title pages, cached in DB
# OMDB_API_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Signup: set ALLOW_PUBLIC_SIGNUP=false for invite-only (email + Plex new users need an invite, except the first user on an empty DB). SITE_ADMIN_EMAILS are comma-separated; those users can create invites under Settings and via POST /api/admin/signup-invites.
# ALLOW_PUBLIC_SIGNUP="true"
# SITE_ADMIN_EMAILS="you@example.com"

# Plex auto-sync cron (generate with: openssl rand -hex 32)
CRON_SECRET="change-me-to-a-random-secret"
# How often to sync Plex watch history (in hours, default: 6)
SYNC_INTERVAL_HOURS=6

# Optional: OpenAI for text embeddings (Movie Night Picker / discovery-style scoring)
# OPENAI_API_KEY=""
